{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-internal-toggle-devtools",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**",
        "$APPLOCALDATA/**",
        "$HOME/**",
        "$DOWNLOAD/**",
        "$DESKTOP/**",
        "$DOCUMENT/**"
      ]
    },
    "os:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-write-text"
  ]
}
