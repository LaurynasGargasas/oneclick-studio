{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-internal-toggle-devtools",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**",
        "$APPLOCALDATA/**"
      ]
    },
    "os:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
